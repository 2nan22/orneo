# Next.js 서버→Django 내부 통신 URL (Docker Compose 내부 또는 로컬)
DJANGO_INTERNAL_URL=http://localhost:8000

# 브라우저에서 직접 접근할 때 사용 (서버사이드 렌더링 외부 노출)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_AI_SERVICE_URL=http://localhost:8001

# AI Service 서버 사이드 전용 (NEXT_PUBLIC_ 접두사 없음 — 브라우저 미노출)
AI_SERVICE_INTERNAL_URL=http://localhost:8001
AI_SERVICE_SECRET=

# 공공데이터포털 인증키 (서버 사이드 전용, 브라우저 미노출)
# 루트 .env의 DATA_GO_KR_SERVICE_KEY와 동일한 값을 사용
DATA_GO_KR_SERVICE_KEY=
MOLIT_APT_TRADE_DETAIL_ENDPOINT=https://apis.data.go.kr/1613000/RTMSDataSvcAptTradeDev
