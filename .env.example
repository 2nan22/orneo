# Django
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_ENV=dev
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend

# Database (PostgreSQL)
POSTGRES_DB=orneo
POSTGRES_USER=orneo
POSTGRES_PASSWORD=
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0

# Social Auth — Google Console: APIs & Services → Credentials → OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=   # ← 필수: 비어 있으면 로그인 400 에러 발생
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# AI Service
AI_SERVICE_URL=http://ai_service:8001
AI_SERVICE_SECRET=

# Ollama (Gemma)
OLLAMA_BASE_URL=http://host.docker.internal:11434
GEMMA_MODEL=gemma4:e2b

# Public Data APIs
# 공공데이터포털 (data.go.kr) 통합 인증키 — MOLIT 실거래가 + K-MOOC 강좌
DATA_GO_KR_SERVICE_KEY=
# DART (전자공시) 오픈API 키 — https://opendart.fss.or.kr 에서 발급
DART_API_KEY=

# Anthropic (P1 이후 사용)
ANTHROPIC_API_KEY=

# Frontend
CORS_ALLOWED_ORIGINS=http://localhost:3000
